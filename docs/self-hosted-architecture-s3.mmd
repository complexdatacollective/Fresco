---
title: "Fresco self-hosted — S3-compatible asset storage (MinIO, private bucket)"
---
flowchart TB
    admin["Researcher browser<br/>(dashboard)"]
    participant["Participant browser<br/>(interview)"]

    subgraph host["Docker host — docker-compose.prod.yml"]
        proxy["<b>Traefik</b> — :80/:443, TLS via Let's Encrypt<br/>FRESCO_DOMAIN → fresco :3000<br/>FRESCO_DOMAIN/assets/* → minio :9000"]
        fresco["<b>Fresco app</b><br/>Next.js :3000"]
        postgres[("PostgreSQL")]
        minio[("MinIO — <b>private</b><br/>bucket 'assets',<br/>no published ports,<br/>no anonymous access")]
    end

    ph["Analytics relay<br/>(optional)"]
    exports["Interview exports stream<br/>Postgres → app → browser<br/>(never stored)"]

    admin -->|"dashboard +<br/>asset upload (presigned PUT,<br/>signed for app domain)"| proxy
    participant -->|"interview +<br/>asset download (/api/assets/key<br/>→ 307 to presigned GET)"| proxy
    proxy --> fresco
    proxy -->|"/assets/*"| minio
    fresco -->|"Prisma"| postgres
    fresco -->|"S3 API — internal<br/>http://minio:9000"| minio
    admin -.->|"events"| ph
    participant -.->|"events"| ph
    fresco -.->|"events"| ph
    fresco -.- exports

    linkStyle 6,7,8,9 stroke:#999,color:#999
