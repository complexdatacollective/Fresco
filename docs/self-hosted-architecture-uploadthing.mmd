    exports["Interview exports stream<br/>Postgres → app → browser<br/>(never stored)"]

    admin -->|"dashboard +<br/>upload authorization"| proxy
    participant -->|"interview"| proxy
    proxy --> fresco
    fresco -->|"Prisma"| postgres
    admin -->|"asset upload<br/>(SDK, direct)"| ut
    participant -->|"asset download<br/>(CDN)"| ut
    fresco -->|"UTApi — assets only<br/>register / delete"| ut
    admin -.->|"events"| ph
    participant -.->|"events"| ph
    fresco -.->|"events"| ph
    fresco -.- exports

    linkStyle 7,8,9,10 stroke:#999,color:#999
